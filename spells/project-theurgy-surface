#!/bin/sh
# Project a Theurgy Product IR file to a target surface.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: project-theurgy-surface PRODUCT_IR --target macos|linux|ios|android
USAGE
  exit 0
  ;;
esac

set -eu

repo_dir=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)
exec cargo run --quiet --manifest-path "$repo_dir/Cargo.toml" --bin theurgy-runtime -- project-surface "$@"
