#!/bin/sh
# Dispatch a typed Theurgy runtime request through a runtime manifest.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: run-theurgy-runtime-request REQUEST_JSON --manifest PATH
USAGE
  exit 0
  ;;
esac

set -eu

repo_dir=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)
exec cargo run --quiet --manifest-path "$repo_dir/Cargo.toml" --bin theurgy-runtime -- run-request "$@"
