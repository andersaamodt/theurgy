#!/bin/sh
# Show the file-first manifest summary for a Theurgy project.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: inspect-theurgy-project [PATH]

Inspect a Theurgy project. If PATH is omitted, the current directory is used.
USAGE
  exit 0
  ;;
esac

set -eu

repo_dir=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)
exec cargo run --quiet --manifest-path "$repo_dir/Cargo.toml" --bin theurgy-runtime -- inspect "$@"

