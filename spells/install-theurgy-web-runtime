#!/bin/sh
# Build and verify the local Theurgy web runtime binary.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install-theurgy-web-runtime

Builds the local theurgy-runtime binary and verifies the web-runtime contract.
Use ./install to expose this spell through the normal user-local wrapper path.
USAGE
  exit 0
  ;;
esac

set -eu

repo_dir=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)
cargo build --quiet --manifest-path "$repo_dir/Cargo.toml" --bin theurgy-runtime
exec "$repo_dir/spells/check-theurgy-web-runtime"
