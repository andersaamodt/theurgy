#!/bin/sh
# Check the Theurgy web runtime integration contract.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: check-theurgy-web-runtime

Report the first-phase Theurgy web runtime contract and its integrated
free-software components.
USAGE
  exit 0
  ;;
esac

set -eu

repo_dir=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)
exec cargo run --quiet --manifest-path "$repo_dir/Cargo.toml" --bin theurgy-runtime -- check-web-runtime
