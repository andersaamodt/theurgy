#!/bin/sh
# Compile a Theurgy Product IR file to a native adapter root.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: compile-theurgy-native PRODUCT_IR --target macos|linux|ios|android --out OUT_DIR
USAGE
  exit 0
  ;;
esac

set -eu

repo_dir=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)
exec "$repo_dir/scripts/theurgy-cargo" run --quiet --manifest-path "$repo_dir/Cargo.toml" --bin theurgy-runtime -- compile-native "$@"
