#!/bin/sh
# Validate a Theurgy runtime state request file.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: validate-theurgy-runtime-state-request PATH
USAGE
  exit 0
  ;;
esac

set -eu

repo_dir=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)
exec "$repo_dir/scripts/theurgy-cargo" run --quiet --manifest-path "$repo_dir/Cargo.toml" --bin theurgy-runtime -- validate-runtime-state-request "$@"
