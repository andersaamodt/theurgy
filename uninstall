#!/bin/sh
# Remove user-local theurgy wrappers and the ~/theurgy install link/checkout.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: uninstall

Removes user-local theurgy spell wrappers and ${THEURGY_HOME:-$HOME/theurgy}.
USAGE
  exit 0
  ;;
esac

set -eu

theurgy_home=${THEURGY_HOME:-${HOME:?}/theurgy}

if [ -n "${XDG_BIN_HOME:-}" ]; then
  bin_dir=$XDG_BIN_HOME
else
  bin_dir=$HOME/.local/bin
fi

if [ -d "$theurgy_home/spells" ]; then
  for spell in "$theurgy_home"/spells/*; do
    [ -f "$spell" ] || continue
    name=$(basename "$spell")
    rm -f "$bin_dir/$name"
  done
fi

if [ -L "$theurgy_home" ]; then
  rm -f "$theurgy_home"
elif [ -d "$theurgy_home/.git" ]; then
  rm -rf "$theurgy_home"
fi

printf 'Removed theurgy\n'
