{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardry.app/schemas/theurgy-mobile-surface-ir-v1.json",
  "title": "Theurgy Mobile Surface IR v1",
  "type": "object",
  "required": ["version", "format", "product", "target", "screens"],
  "properties": {
    "version": { "const": "theurgy-mobile-surface-ir/v1" },
    "format": { "const": "json" },
    "product": { "type": "string", "minLength": 1 },
    "target": { "enum": ["mobile", "ios", "android"] },
    "screens": { "type": "array", "items": { "$ref": "#/$defs/screen" }, "minItems": 1 },
    "actions": { "$ref": "#/$defs/actionIdList" },
    "capabilities": { "$ref": "#/$defs/capabilityList" },
    "permissions": { "$ref": "#/$defs/capabilityList" },
    "backgroundModes": { "$ref": "#/$defs/capabilityList" },
    "offlineAffordances": { "$ref": "#/$defs/capabilityList" }
  },
  "$defs": {
    "capabilityList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "screen": {
      "type": "object",
      "required": ["id", "title", "node"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "actions": { "$ref": "#/$defs/actionIdList" },
        "node": { "$ref": "#/$defs/node" }
      },
      "additionalProperties": true
    },
    "actionIdList": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
      "uniqueItems": true
    },
    "node": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
        "action": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
        "actions": { "$ref": "#/$defs/actionIdList" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } },
        "child": { "$ref": "#/$defs/node" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
