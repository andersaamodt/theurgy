{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardry.app/schemas/theurgy-generated-runtime-v1.json",
  "title": "Theurgy Generated Runtime Metadata v1",
  "type": "object",
  "required": [
    "version",
    "app",
    "target",
    "productIr",
    "runtimeManifest",
    "sourceSurfaceIr",
    "compatibilityWizardryAppsShellFirstStillSupported",
    "compatibilityTheurgyRequiredForLegacyWizardryApps",
    "protocol",
    "runtimeStatusSchema",
    "runtimeActionRequestSchema",
    "runtimeActionResultSchema",
    "operationStatusRequestSchema",
    "operationHistoryRequestSchema",
    "operationStatusSchema",
    "operationHistorySchema",
    "targetReleaseTarget",
    "targetReleaseArtifact",
    "stateCommand",
    "subscribeStatusCommand",
    "actionCommand",
    "productTargets",
    "productActions",
    "productActionContracts",
    "productStateSnapshotSchema",
    "productStateProjections",
    "productPersistenceTruth",
    "adapterRuntimeTransport",
    "surface",
    "surfaceSchema",
    "surfaceTarget",
    "productDomainObjectContracts",
    "productPersistenceRootContracts",
    "productBackgroundJobContracts",
    "productReleaseTargetContracts",
    "surfaceActions",
    "surfaceActionContracts",
    "surfaceRoles"
  ],
  "properties": {
    "version": { "const": "theurgy-generated-runtime/v1" },
    "app": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "target": { "enum": ["macos", "linux", "ios", "android"] },
    "productIr": { "type": "string", "minLength": 1 },
    "runtimeManifest": { "type": "string", "minLength": 1 },
    "sourceSurfaceIr": { "type": "string", "minLength": 1 },
    "legacyNativeDesktopIr": { "type": "string", "minLength": 1 },
    "compatibilityWizardryAppsShellFirstStillSupported": { "type": "boolean" },
    "compatibilityTheurgyRequiredForLegacyWizardryApps": { "type": "boolean" },
    "protocol": { "type": "string", "minLength": 1 },
    "runtimeStatusSchema": {
      "const": "theurgy-runtime-status/v1"
    },
    "runtimeActionRequestSchema": {
      "const": "theurgy-runtime-action-request/v1"
    },
    "runtimeActionResultSchema": {
      "const": "theurgy-runtime-action-result/v1"
    },
    "operationStatusRequestSchema": {
      "const": "theurgy-operation-status-request/v1"
    },
    "operationHistoryRequestSchema": {
      "const": "theurgy-operation-history-request/v1"
    },
    "operationStatusSchema": {
      "const": "theurgy-operation-status/v1"
    },
    "operationHistorySchema": {
      "const": "theurgy-operation-history/v1"
    },
    "targetReleaseTarget": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
    "targetReleaseArtifact": { "type": "string", "minLength": 1 },
    "stateCommand": { "$ref": "#/$defs/command" },
    "statusCommand": { "$ref": "#/$defs/command" },
    "subscribeStatusCommand": { "$ref": "#/$defs/command" },
    "operationStatusCommand": { "$ref": "#/$defs/command" },
    "actionCommand": { "$ref": "#/$defs/command" },
    "historyCommand": { "$ref": "#/$defs/command" },
    "daemonCommand": { "$ref": "#/$defs/command" },
    "productTargets": { "$ref": "#/$defs/stringList" },
    "productActions": { "$ref": "#/$defs/actionIdList" },
    "productActionContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/actionContract" },
      "minItems": 1
    },
    "productCapabilities": { "$ref": "#/$defs/stringList" },
    "productPermissions": { "$ref": "#/$defs/stringList" },
    "productDomainObjects": { "$ref": "#/$defs/stringList" },
    "productDomainObjectContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/domainObjectContract" }
    },
    "productStateSnapshotSchema": { "type": "string", "minLength": 1 },
    "productStateProjections": { "$ref": "#/$defs/stringList" },
    "productPersistenceTruth": { "type": "string", "minLength": 1 },
    "adapterRuntimeTransport": {
      "enum": ["local-process-json", "external-json-abi"]
    },
    "productPersistenceRoots": { "$ref": "#/$defs/stringList" },
    "productPersistenceRootContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/persistenceRootContract" }
    },
    "productBackgroundJobs": { "$ref": "#/$defs/stringList" },
    "productBackgroundJobContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/backgroundJobContract" }
    },
    "productReleaseTargets": { "$ref": "#/$defs/stringList" },
    "productReleaseTargetContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/releaseTargetContract" },
      "minItems": 1
    },
    "productAuditKeys": { "$ref": "#/$defs/stringList" },
    "surface": { "type": "string", "minLength": 1 },
    "surfaceSchema": {
      "enum": ["theurgy-desktop-surface-ir/v1", "theurgy-mobile-surface-ir/v1"]
    },
    "surfaceTarget": { "type": "string", "minLength": 1 },
    "surfaceActions": { "$ref": "#/$defs/actionIdList" },
    "surfaceActionContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/actionContract" }
    },
    "surfaceRoles": { "$ref": "#/$defs/stringList" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "target": { "enum": ["macos", "linux"] } },
        "required": ["target"]
      },
      "then": {
        "properties": {
          "adapterRuntimeTransport": { "const": "local-process-json" },
          "surfaceSchema": { "const": "theurgy-desktop-surface-ir/v1" },
          "surfaceTarget": { "enum": ["desktop", "macos", "linux"] }
        }
      }
    },
    {
      "if": {
        "properties": { "target": { "enum": ["ios", "android"] } },
        "required": ["target"]
      },
      "then": {
        "properties": {
          "adapterRuntimeTransport": { "const": "external-json-abi" },
          "surfaceSchema": { "const": "theurgy-mobile-surface-ir/v1" },
          "surfaceTarget": { "enum": ["mobile", "ios", "android"] }
        }
      }
    }
  ],
  "$defs": {
    "command": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actionIdList": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" }
    },
    "actionContract": {
      "type": "object",
      "required": [
        "id",
        "label",
        "effect",
        "safe",
        "mutating",
        "longRunning",
        "privileged",
        "inputKeys",
        "outputKeys",
        "failureKeys",
        "inputShape",
        "outputShape",
        "failureShape"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
        "label": { "type": "string", "minLength": 1 },
        "effect": { "enum": ["read", "write", "background", "external", "release"] },
        "safe": { "type": "boolean" },
        "mutating": { "type": "boolean" },
        "longRunning": { "type": "boolean" },
        "privileged": { "type": "boolean" },
        "inputKeys": { "$ref": "#/$defs/stringList" },
        "outputKeys": { "$ref": "#/$defs/stringList" },
        "failureKeys": { "$ref": "#/$defs/stringList" },
        "inputShape": { "$ref": "#/$defs/shape" },
        "outputShape": { "$ref": "#/$defs/shape" },
        "failureShape": { "$ref": "#/$defs/shape" }
      },
      "additionalProperties": false
    },
    "backgroundJobContract": {
      "type": "object",
      "required": ["id", "label", "command"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
        "label": { "type": "string", "minLength": 1 },
        "command": { "$ref": "#/$defs/command" },
        "state": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "persistenceRootContract": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "releaseTargetContract": {
      "type": "object",
      "required": ["id", "target", "surface", "artifact"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
        "target": { "enum": ["macos", "linux", "ios", "android"] },
        "surface": { "enum": ["desktop", "mobile"] },
        "artifact": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "domainObjectContract": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
        "label": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "shape": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/shapeDescriptor" }
    },
    "shapeDescriptor": {
      "type": "string",
      "pattern": "^([a-z][a-z0-9_-]*(\\|[a-z][a-z0-9_-]*)*\\??)$"
    }
  },
  "additionalProperties": false
}
