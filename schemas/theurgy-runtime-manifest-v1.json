{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardry.app/schemas/theurgy-runtime-manifest-v1.json",
  "title": "Theurgy Runtime Manifest v1",
  "type": "object",
  "required": ["version", "app", "productIr", "runtime"],
  "properties": {
    "version": { "const": "theurgy-runtime-manifest/v1" },
    "app": { "type": "string", "minLength": 1 },
    "productIr": { "type": "string", "minLength": 1 },
    "runtime": {
      "type": "object",
      "required": ["stateCommand", "actionCommand", "protocol"],
      "properties": {
        "stateCommand": { "$ref": "#/$defs/command" },
        "statusCommand": { "$ref": "#/$defs/command" },
        "subscribeStatusCommand": { "$ref": "#/$defs/command" },
        "actionCommand": { "$ref": "#/$defs/command" },
        "historyCommand": { "$ref": "#/$defs/command" },
        "daemonCommand": { "$ref": "#/$defs/command" },
        "protocol": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "surfaces": {
      "type": "object",
      "properties": {
        "desktop": { "type": "string", "minLength": 1 },
        "mobile": { "type": "string", "minLength": 1 },
        "legacyNativeDesktop": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "wizardryAppsShellFirstStillSupported": { "type": "boolean" },
        "theurgyRequiredForLegacyWizardryApps": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "command": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "additionalProperties": true
}
