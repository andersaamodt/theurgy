#!/bin/sh
# Install theurgy at ~/theurgy and expose its spells by name.

case "${1-}" in
--help|--usage|-h)
  cat <<'USAGE'
Usage: install [--uninstall]

Installs theurgy to ${THEURGY_HOME:-$HOME/theurgy} and writes user-local
wrappers for theurgy spells.

Use --uninstall to remove theurgy wrappers and the ${THEURGY_HOME:-$HOME/theurgy}
install link/checkout.
USAGE
  exit 0
  ;;
esac

set -eu

script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
theurgy_home=${THEURGY_HOME:-${HOME:?}/theurgy}

if [ -n "${XDG_BIN_HOME:-}" ]; then
  bin_dir=$XDG_BIN_HOME
elif [ -d "$HOME/.local/bin" ]; then
  bin_dir=$HOME/.local/bin
else
  bin_dir=$HOME/.local/bin
fi

uninstall_mode=0
case "${1-}" in
  --uninstall)
    uninstall_mode=1
    ;;
  "")
    ;;
  *)
    printf '%s\n' "install: unknown option '$1'" >&2
    exit 2
    ;;
esac

if [ "$uninstall_mode" -eq 1 ]; then
  if [ -d "$theurgy_home/spells" ]; then
    for spell in "$theurgy_home"/spells/*; do
      [ -f "$spell" ] || continue
      name=$(basename "$spell")
      rm -f "$bin_dir/$name"
    done
  fi

  if [ -L "$theurgy_home" ]; then
    rm -f "$theurgy_home"
  elif [ -d "$theurgy_home/.git" ]; then
    rm -rf "$theurgy_home"
  fi

  printf 'Removed theurgy\n'
  exit 0
fi

mkdir -p "$(dirname "$theurgy_home")" "$bin_dir"

if [ "$script_dir" != "$theurgy_home" ]; then
  if [ -L "$theurgy_home" ]; then
    existing_target=$(readlink "$theurgy_home")
    if [ "$existing_target" != "$script_dir" ]; then
      printf '%s\n' "install: $theurgy_home already points to $existing_target" >&2
      exit 1
    fi
  elif [ -e "$theurgy_home" ]; then
    printf '%s\n' "install: $theurgy_home already exists and is not this checkout" >&2
    exit 1
  else
    ln -s "$script_dir" "$theurgy_home"
  fi
fi

for spell in "$script_dir"/spells/*; do
  [ -f "$spell" ] || continue
  [ -x "$spell" ] || continue
  name=$(basename "$spell")
  tmp_file=$(mktemp "${TMPDIR:-/tmp}/theurgy-wrapper.XXXXXX")
  cat >"$tmp_file" <<WRAPPER
#!/bin/sh
set -eu
exec "\${THEURGY_HOME:-\$HOME/theurgy}/spells/$name" "\$@"
WRAPPER
  chmod 755 "$tmp_file"
  mv "$tmp_file" "$bin_dir/$name"
done

printf 'Installed theurgy\n'
printf 'Home: %s\n' "$theurgy_home"
printf 'Wrappers: %s\n' "$bin_dir"
